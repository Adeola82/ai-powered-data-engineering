    },
    {
      "name": "b7ee0ece",
      "displayName": "Tier Growth Monthly",
      "queryLines": [
        "SELECT\n",
        "  DATE_TRUNC('month', created_at) AS month,\n",
        "  loyalty_tier,\n",
        "  COUNT(*) AS new_customers,\n",
        "  SUM(total_spent) AS monthly_revenue,\n",
        "  SUM(COUNT(*)) OVER (\n",
        "      PARTITION BY loyalty_tier\n",
        "      ORDER BY DATE_TRUNC('month', created_at)\n",
        "    ) AS cumulative_customers,\n",
        "  SUM(SUM(total_spent)) OVER (\n",
        "      PARTITION BY loyalty_tier\n",
        "      ORDER BY DATE_TRUNC('month', created_at)\n",
        "    ) AS cumulative_revenue\n",
        "FROM\n",
        "  silver_customers\n",
        "GROUP BY\n",
        "  DATE_TRUNC('month', created_at),\n",
        "  loyalty_tier\n",
        "ORDER BY\n",
        "  month,\n",
        "  loyalty_tier"
      ],
      "catalog": "demo",
      "schema": "labuser14186681_1773675394"
    }
  ],
